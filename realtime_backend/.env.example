# Collective MindGraph Realtime Backend Configuration

# General
CMG_RT_HOST=127.0.0.1
CMG_RT_PORT=8080
CMG_RT_LOG_LEVEL=INFO
# CMG_RT_LANGUAGE=tr

# VAD (Voice Activity Detection)
CMG_RT_VAD_PROVIDER=silero

# ASR (Speech-to-Text)
# `auto` prefers local faster-whisper if available, otherwise falls back to MockASR.
CMG_RT_ASR_PROVIDER=auto
CMG_RT_ASR_MODEL=large-v3-turbo
CMG_RT_ASR_DEVICE=cuda
CMG_RT_ASR_COMPUTE_TYPE=float16

# Diarization (Speaker identification)
CMG_RT_DIARIZATION_ENABLED=false
CMG_RT_DIARIZER_PROVIDER=pyannote
CMG_RT_DIARIZER_DEVICE=cuda
# Hugging Face token for pyannote models (required for diarization)
# CMG_RT_PYANNOTE_TOKEN=hf_your_token_here

# LLM (Transcript Correction)
# Use local providers like LM Studio or Ollama.
# Legacy names: CMG_RT_LLM_PROVIDER, CMG_RT_LLM_ENDPOINT
CMG_LOCAL_LLM_PROVIDER=lmstudio
CMG_LOCAL_LLM_ENDPOINT=http://127.0.0.1:1234/v1
CMG_RT_LLM_MODEL=auto
CMG_RT_LLM_CONTEXT_SEGMENTS=4
CMG_RT_ENABLE_SUMMARY=true

# Safety
CMG_ALLOW_REMOTE_ACCESS=false
CMG_ALLOW_REMOTE_DOWNLOAD=false
