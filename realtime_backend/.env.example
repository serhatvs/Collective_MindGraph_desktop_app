# Optional local runtime config for the realtime backend.
# Copy to `.env` and fill values you actually need.

# Hugging Face token for gated pyannote diarization models.
CMG_RT_PYANNOTE_TOKEN=hf_your_token_here

# Optional online-first STT config.
# If set, backend `CMG_RT_ASR_PROVIDER=auto` will prefer Deepgram Nova-3
# and fall back to local faster-whisper only if Deepgram is unavailable.
# CMG_RT_DEEPGRAM_API_KEY=dg_your_api_key_here
# CMG_RT_DEEPGRAM_MODEL=nova-3

# Optional Amazon Bedrock LLM correction config.
# `bedrock_auto_local` tries Amazon Nova on Bedrock first and falls back
# to LM Studio / mock cleanup if AWS credentials are unavailable.
# CMG_RT_LLM_PROVIDER=bedrock_auto_local
# CMG_RT_BEDROCK_REGION=us-east-1
# CMG_RT_BEDROCK_MODEL_ID=us.amazon.nova-2-lite-v1:0
# CMG_RT_BEDROCK_PROFILE=default

# Optional local LLM settings.
# `auto_local` tries LM Studio first and falls back safely if no local server is up.
# CMG_RT_LLM_PROVIDER=auto_local
# CMG_RT_LLM_ENDPOINT=http://127.0.0.1:1234/v1
# CMG_RT_LLM_MODEL=auto
