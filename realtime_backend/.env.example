# Optional local runtime config for the realtime backend.
# Copy to `.env` and fill values you actually need.

# Hugging Face token for gated pyannote diarization models.
CMG_RT_PYANNOTE_TOKEN=hf_your_token_here

# Optional LM Studio / OpenAI-compatible LLM settings.
# CMG_RT_LLM_PROVIDER=lmstudio
# CMG_RT_LLM_ENDPOINT=http://127.0.0.1:1234/v1
# CMG_RT_LLM_MODEL=qwen3-vl-8b-instruct
